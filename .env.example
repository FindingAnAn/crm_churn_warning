# ════════════════════════════════════════════════════════════════════════════════
# ENVIRONMENT — Select deployment environment
# ════════════════════════════════════════════════════════════════════════════════

# ENVIRONMENT: Select which set of defaults to use
#              Options: development, production, testing
#              Used by: config.settings.get_config() to select public defaults
#              Defaults file: config/defaults.py
ENVIRONMENT=development

# ════════════════════════════════════════════════════════════════════════════════
# APPLICATION DATABASE
# ════════════════════════════════════════════════════════════════════════════════

PG_HOST=CHANGE_ME            # Example: 172.16.2.142 or 172.20.0.65
PG_PORT=CHANGE_ME            # Example: 25432 or 5432 or 5433
PG_DB=CHANGE_ME              # Example: churn_prediction or cpuser    
PG_USER=CHANGE_ME            # Example: cpuser
PG_PASSWORD=CHANGE_ME
DATABASE_URL=CHANGE_ME

# ════════════════════════════════════════════════════════════════════════════════
# AIRFLOW INFRASTRUCTURE
# ════════════════════════════════════════════════════════════════════════════════

_AIRFLOW_WWW_USER_PASSWORD=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
AIRFLOW__CORE__FERNET_KEY=

