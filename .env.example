# Environment
ENVIRONMENT=development

# Application database
# Required by settings.database.PostgresConfig and config.settings.
PG_HOST=localhost
PG_PORT=5432
PG_DB=churn
PG_USER=CHANGE_ME
PG_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+psycopg2://CHANGE_ME:CHANGE_ME@localhost:5432/churn

# Runtime paths mounted into Docker/Kubernetes pods
INCOMING_DIR=/churn_data/incoming
SAVED_DIR=/churn_data/saved
FAIL_DIR=/churn_data/failed
CSKH_DIR=/churn_data/cskh_confirm_churn
# Optional single-file mode. Leave empty when CSKH_DIR is used.
CSKH_FILE_PATH=
LOGS_DIR=/churn_data/logs
CHURN_MODEL_DIR=/churn_data/models

# Dataset and modeling contract
CHURN_MODEL_SCHEDULE=0 5 * * 6
FEATURE_START_DATE=2025-01-01
CHURN_PREDICTION_HORIZON_MONTHS=2
CHURN_RISK_THRESHOLD_PCT=90

# Model-quality monitoring in PostgreSQL
ENABLE_MODEL_QUALITY_MONITORING=true
ML_MONITOR_SCHEMA=ml_monitor
ML_MONITOR_FEATURE_BINS=10
ML_MONITOR_MAX_FEATURES=200

# Local Kubernetes / Airflow pod runtime
CHURN_DATA_HOST_PATH=/churn_data
CHURN_DATA_MOUNT_PATH=/churn_data
CHURN_DB_SECRET_NAME=churn-db-secret
CHURN_APP_IMAGE=churn_app:latest
CHURN_AIRFLOW_IMAGE=churn_app_airflow:latest

# Airflow infrastructure secrets
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.
DATA_DIR=/data/churn_prediction/ftp_churn
ENV_FILE_PATH=.env

# Housekeeping retention
BUNDLE_KEEP_COUNT=10
LOG_RETENTION_DAYS=30
SAVED_RETENTION_DAYS=90
FAIL_RETENTION_DAYS=30
INCOMING_RETENTION_DAYS=7
